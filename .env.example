# ─────────────────────────────────────────────────────────────
# Marjos Designs — Environment variables
# Copy to .env.local for local dev. In Vercel, set these in
# Project Settings → Environment Variables.
# NEVER commit real values. NEVER paste secrets in chat or logs.
# ─────────────────────────────────────────────────────────────

# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase key. SENSITIVE.
# Mark as "Sensitive" in Vercel. NEVER prefix with NEXT_PUBLIC_.
# Only used in server-side code (Route Handlers / Server Actions).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lectura de factura (visión de IA) — SERVER-ONLY, SENSITIVE.
# Usada solo en el servidor para transcribir la foto del recibo en Gastos.
# Sin esta key, la app funciona igual pero la lectura automática queda inactiva
# (avisa con gracia). NUNCA con prefijo NEXT_PUBLIC_. NUNCA en logs.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Opcional: modelo de visión (por defecto claude-3-5-sonnet-latest).
# RECEIPT_OCR_MODEL=claude-3-5-sonnet-latest
